{
  "name": "better-react",
  "version": "2.0.1",
  "description": "A better React framework with enhanced features and performance",
  "keywords": [
    "react",
    "framework",
    "better-react",
    "ui"
  ],
  "author": "wy2010344",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wy2010344/better-react.git"
  },
  "homepage": "https://github.com/wy2010344/better-react#readme",
  "bugs": {
    "url": "https://github.com/wy2010344/better-react/issues"
  },
  "files": [
    "src",
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint src/ --fix",
    "lint:check": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "wy-helper": "workspace:*"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/prettier-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "tsdown": "latest"
  },
  "packageManager": "pnpm@10.33.0"
}